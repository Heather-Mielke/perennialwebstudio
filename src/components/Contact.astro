---
import { contactInterestedOptions } from "../data/pricing.ts";
---

<section id="contact" class="section section--contact">
  <div class="contact-layout">
    <div class="contact-intro">
      <p class="contact-intro__eyebrow">Let's talk</p>
      <h2 class="contact-intro__title">Ready to grow your online presence?</h2>
      <p class="contact-intro__lede">
        Fill out the form and we’ll reach out to discuss your project. No pressure, no obligations—just a friendly
        conversation about how we can help your business shine online.
      </p>
      <ol class="contact-steps">
        <li class="contact-steps__item">
          <span class="contact-steps__num" aria-hidden="true">01</span>
          <span class="contact-steps__text">Tell us about your business and goals</span>
        </li>
        <li class="contact-steps__item">
          <span class="contact-steps__num" aria-hidden="true">02</span>
          <span class="contact-steps__text">We’ll create a custom plan and timeline</span>
        </li>
        <li class="contact-steps__item">
          <span class="contact-steps__num" aria-hidden="true">03</span>
          <span class="contact-steps__text">Sit back while we build your dream site</span>
        </li>
      </ol>
    </div>

    <div class="contact-form-shell">
      <form class="form form--contact-card" name="contact" method="POST" data-netlify="true">
        <input type="hidden" name="form-name" value="contact" />

        <div class="form__row form__row--split">
          <div class="form__field">
            <label class="form__label" for="contact-name">Name *</label>
            <input
              class="form__control"
              id="contact-name"
              name="name"
              type="text"
              required
              autocomplete="name"
              placeholder="Your name"
            />
          </div>
          <div class="form__field">
            <label class="form__label" for="contact-email">Email *</label>
            <input
              class="form__control"
              id="contact-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="you@example.com"
            />
          </div>
        </div>

        <div class="form__row form__row--split">
          <div class="form__field">
            <label class="form__label" for="contact-phone">Phone</label>
            <input
              class="form__control"
              id="contact-phone"
              name="phone"
              type="tel"
              autocomplete="tel"
              placeholder="(555) 123-4567"
            />
          </div>
          <div class="form__field">
            <label class="form__label" for="contact-business">Business name *</label>
            <input
              class="form__control"
              id="contact-business"
              name="business"
              type="text"
              required
              autocomplete="organization"
              placeholder="Your business"
            />
          </div>
        </div>

        <div class="form__field">
          <label class="form__label" for="contact-industry-trade">
            Industry or trade <span class="form__label-optional">(optional)</span>
          </label>
          <input
            class="form__control"
            id="contact-industry-trade"
            name="industry"
            type="text"
            autocomplete="on"
            placeholder="e.g. dental practice, retail, construction"
          />
        </div>

        <div class="form__field form__field--contact-gap-top">
          <label class="form__label" for="contact-interested">Interested in</label>
          <div class="form__select-wrap">
            <select class="form__control form__control--select" id="contact-interested" name="interested">
              <option value="">Select a service or plan</option>
              {contactInterestedOptions.map((label) => (
                <option value={label}>{label}</option>
              ))}
            </select>
          </div>
        </div>

        <div class="form__field form__field--contact-gap-top">
          <label class="form__label" for="contact-message">Message *</label>
          <textarea
            class="form__control form__control--textarea"
            id="contact-message"
            name="message"
            rows="5"
            required
            placeholder="Tell us about your project or ask any questions…"
          />
        </div>

        <button class="button button--contact-submit" type="submit">
          <svg class="button__icon" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path fill="currentColor" d="M2.01 21 23 12 2.01 3 2 10l15 2-15 2z" />
          </svg>
          Send message
        </button>
      </form>
    </div>
  </div>
</section>
