---
import { contactInterestedOptions } from "../data/pricing.ts";

/** Vercel / static: get a key at https://web3forms.com (free), add in Vercel → Settings → Environment Variables */
const web3AccessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? "";
const siteUrl = (import.meta.env.PUBLIC_SITE_URL ?? "").replace(/\/$/, "");
const contactRedirect = siteUrl ? `${siteUrl}/#contact?sent=1` : "";
---

<section id="contact" class="section section--contact">
  <div class="contact-layout">
    <div class="contact-intro">
      <p class="contact-intro__eyebrow">Let's talk</p>
      <h2 class="contact-intro__title">Ready to grow your online presence?</h2>
      <p class="contact-intro__lede">
        Fill out the form and we’ll reach out to discuss your project. No pressure, no obligations—just a friendly
        conversation about how we can help your business shine online.
      </p>
      <ol class="contact-steps">
        <li class="contact-steps__item">
          <span class="contact-steps__num" aria-hidden="true">01</span>
          <span class="contact-steps__text">Tell us about your business and goals</span>
        </li>
        <li class="contact-steps__item">
          <span class="contact-steps__num" aria-hidden="true">02</span>
          <span class="contact-steps__text">We’ll create a custom plan and timeline</span>
        </li>
        <li class="contact-steps__item">
          <span class="contact-steps__num" aria-hidden="true">03</span>
          <span class="contact-steps__text">Sit back while we build your dream site</span>
        </li>
      </ol>
    </div>

    <div class="contact-form-shell">
      {import.meta.env.DEV && !web3AccessKey ? (
        <p class="contact-form-dev-hint" role="status">
          Add <code>PUBLIC_WEB3FORMS_ACCESS_KEY</code> to <code>.env</code> (see <code>.env.example</code>) so submissions
          reach your email on Vercel.
        </p>
      ) : null}
      <div
        class="contact-form-alert contact-form-alert--success"
        data-contact-success
        role="status"
        aria-live="polite"
        hidden
      >
        Thanks — your message was sent. We’ll be in touch soon.
      </div>
      <div class="contact-form-alert contact-form-alert--error" data-contact-error role="alert" aria-live="assertive" hidden>
        Something went wrong. Please try again, or email us directly.
      </div>
      <form
        class="form form--contact-card"
        name="contact"
        method="POST"
        action="https://api.web3forms.com/submit"
      >
        <input type="hidden" name="access_key" value={web3AccessKey} />
        <input type="hidden" name="subject" value="Contact form — Perennial Web Studio" />
        {contactRedirect ? <input type="hidden" name="redirect" value={contactRedirect} /> : null}
        <input type="checkbox" name="botcheck" class="contact-form-honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />

        <div class="form__row form__row--split">
          <div class="form__field">
            <label class="form__label" for="contact-name">Name *</label>
            <input
              class="form__control"
              id="contact-name"
              name="name"
              type="text"
              required
              autocomplete="name"
              placeholder="Your name"
            />
          </div>
          <div class="form__field">
            <label class="form__label" for="contact-email">Email *</label>
            <input
              class="form__control"
              id="contact-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="you@example.com"
            />
          </div>
        </div>

        <div class="form__row form__row--split">
          <div class="form__field">
            <label class="form__label" for="contact-phone">Phone</label>
            <input
              class="form__control"
              id="contact-phone"
              name="phone"
              type="tel"
              autocomplete="tel"
              placeholder="(555) 123-4567"
            />
          </div>
          <div class="form__field">
            <label class="form__label" for="contact-business">Business name *</label>
            <input
              class="form__control"
              id="contact-business"
              name="business"
              type="text"
              required
              autocomplete="organization"
              placeholder="Your business"
            />
          </div>
        </div>

        <div class="form__field">
          <label class="form__label" for="contact-industry-trade">
            Industry or trade <span class="form__label-optional">(optional)</span>
          </label>
          <input
            class="form__control"
            id="contact-industry-trade"
            name="industry"
            type="text"
            autocomplete="on"
            placeholder="e.g. dental practice, retail, construction"
          />
        </div>

        <div class="form__field form__field--contact-gap-top">
          <label class="form__label" for="contact-interested">Interested in</label>
          <div class="form__select-wrap">
            <select class="form__control form__control--select" id="contact-interested" name="interested">
              <option value="">Select a service or plan</option>
              {contactInterestedOptions.map((label) => (
                <option value={label}>{label}</option>
              ))}
            </select>
          </div>
        </div>

        <div class="form__field form__field--contact-gap-top">
          <label class="form__label" for="contact-message">Message *</label>
          <textarea
            class="form__control form__control--textarea"
            id="contact-message"
            name="message"
            rows="5"
            required
            placeholder="Tell us about your project or ask any questions…"
          />
        </div>

        <button class="button button--contact-submit" type="submit" data-contact-submit>
          <svg class="button__icon" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path fill="currentColor" d="M2.01 21 23 12 2.01 3 2 10l15 2-15 2z" />
          </svg>
          <span data-contact-submit-label>Send message</span>
        </button>
      </form>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const SUCCESS_MS = 6000;
    var successHideTimer;

    function parseHashQuery() {
      var raw = window.location.hash.replace(/^#/, "");
      var q = raw.indexOf("?");
      if (q === -1) return null;
      return new URLSearchParams(raw.slice(q + 1));
    }

    function stripSentFromHash() {
      var raw = window.location.hash.replace(/^#/, "");
      var q = raw.indexOf("?");
      if (q === -1) return;
      var path = raw.slice(0, q);
      var params = new URLSearchParams(raw.slice(q + 1));
      params.delete("sent");
      var next = params.toString() === "" ? "#" + path : "#" + path + "?" + params.toString();
      history.replaceState(null, "", window.location.pathname + window.location.search + next);
    }

    function wireContactForm() {
      var root = document.getElementById("contact");
      if (!root || root.dataset.contactWired === "true") return;

      var form = root.querySelector('form[name="contact"]');
      var successEl = root.querySelector("[data-contact-success]");
      var errorEl = root.querySelector("[data-contact-error]");
      var submitBtn = root.querySelector("[data-contact-submit]");
      var submitLabel = root.querySelector("[data-contact-submit-label]");

      if (!form || !successEl || !errorEl || !submitBtn) return;
      root.dataset.contactWired = "true";

      function hideAlerts() {
        successEl.hidden = true;
        errorEl.hidden = true;
      }

      function showSuccess() {
        if (successHideTimer !== undefined) clearTimeout(successHideTimer);
        hideAlerts();
        successEl.hidden = false;
        successEl.scrollIntoView({ behavior: "smooth", block: "nearest" });
        successHideTimer = window.setTimeout(function () {
          successEl.hidden = true;
          successHideTimer = undefined;
        }, SUCCESS_MS);
      }

      function showError() {
        if (successHideTimer !== undefined) {
          clearTimeout(successHideTimer);
          successHideTimer = undefined;
        }
        hideAlerts();
        errorEl.hidden = false;
        errorEl.scrollIntoView({ behavior: "smooth", block: "nearest" });
      }

      var hashParams = parseHashQuery();
      if (hashParams && hashParams.get("sent") === "1") {
        showSuccess();
        stripSentFromHash();
      }

      form.addEventListener("submit", async function (e) {
        e.preventDefault();
        hideAlerts();

        var accessKeyInput = form.querySelector('input[name="access_key"]');
        if (!accessKeyInput || !accessKeyInput.value) {
          showError();
          return;
        }

        var formData = new FormData(form);
        var payload = {};
        formData.forEach(function (value, key) {
          if (typeof value === "string" && key !== "redirect") payload[key] = value;
        });

        submitBtn.disabled = true;
        if (submitLabel) submitLabel.textContent = "Sending…";

        try {
          var res = await fetch("https://api.web3forms.com/submit", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Accept: "application/json",
            },
            body: JSON.stringify(payload),
          });
          var data = await res.json();

          if (res.ok && data.success) {
            form.reset();
            showSuccess();
          } else {
            showError();
          }
        } catch (err) {
          showError();
        } finally {
          submitBtn.disabled = false;
          if (submitLabel) submitLabel.textContent = "Send message";
        }
      });
    }

    function initContactForm() {
      wireContactForm();
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initContactForm, { once: true });
    } else {
      initContactForm();
    }
  })();
</script>
