<section class="hero full-bleed">
  <span class="hero__bg-leaves-wrap" aria-hidden="true">
    <img
      class="hero__bg-leaves"
      src="/hero-leaves.png"
      alt=""
      width="400"
      height="400"
      loading="eager"
      decoding="async"
      aria-hidden="true"
    />
  </span>
  <div class="hero__inner hero__inner--centered">
    <div class="hero__content hero__content--center">
      <p class="hero__eyebrow hero__intro-el">Rooted in design · Built to last</p>

      <h1 class="hero__title hero__intro-el">
        <span class="hero__title-line">Professional websites</span>
        <span class="hero__title-line hero__title-line--accent">for small businesses</span>
      </h1>

      <p class="hero__text hero__intro-el">
        We craft clean, fast, and professional static websites that help your business grow—no unnecessary complexity,
        just elegant design that works.
      </p>

      <div class="hero__actions hero__intro-el">
        <a class="button button--primary" href="/#pricing">View pricing</a>
        <a class="button button--secondary" href="/#contact">Get a quote</a>
      </div>

      <p class="hero__note hero__intro-el">
        You don’t need to be a designer. We’ll pick a sensible look together, then arrange proven sections so the page
        fits how you work—not a generic template clone.
      </p>
    </div>
  </div>

  <a class="hero__scroll hero__intro-scroll" href="#pricing" aria-label="Scroll to website packages">
    <span class="hero__scroll-bounce" aria-hidden="true">
      <svg class="hero__scroll-icon" width="28" height="28" viewBox="0 0 24 24" focusable="false">
        <path
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          d="m7 10 5 5 5-5"
        />
      </svg>
    </span>
  </a>
</section>
