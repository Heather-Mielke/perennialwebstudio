---
const services = [
  {
    title: "Landing page",
    desc: "One scrolling page with clear sections—what you do, how to reach you, and where you’re based.",
    bullets: [
      "Hero and key message",
      "Services or offers",
      "Contact and location blocks",
      "Mobile-friendly layout",
    ],
  },
  {
    title: "Small site (up to 5 pages)",
    desc: "Separate pages when you need a bit more room—still static content, no accounts or payments.",
    bullets: [
      "Typical: Home, About, Services, Contact, Location or Hours",
      "Component-based sections you help place",
      "Mobile-friendly design",
      "Basic search engine setup",
    ],
  },
  {
    title: "Expanded site (up to 7 pages)",
    desc: "Extra pages for FAQs, more services, or galleries—same straightforward approach, more structure.",
    bullets: [
      "Up to 7 content pages",
      "Organized layouts from shared components",
      "Still no auth or transactions",
      "Basic analytics setup",
    ],
  },
  {
    title: "Monthly care plans",
    desc: "Optional help after launch so you’re not stuck editing copy or images alone.",
    bullets: [
      "Text or image tweaks",
      "Minor fixes",
      "Backups and light monitoring",
      "Email support",
    ],
  },
];
---
<section id="services" class="section section--services">
  <div class="section__head">
    <p class="section__eyebrow">What we offer</p>
    <h2>Services</h2>
    <p>
      Marketing and brochure-style sites for small businesses. If you need custom software, member logins, or online
      payments, I’ll gladly point you to partners—my focus stays on fast, maintainable pages.
    </p>
  </div>

  <div class="services">
    <div class="services__grid">
      {services.map((s) => (
        <article class="service-card">
          <h3>{s.title}</h3>
          <p>{s.desc}</p>

          <ul class="service-card__list">
            {s.bullets.map((b) => (
              <li>{b}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <p class="services-scope" role="note">
      <strong>Not in scope:</strong> custom apps, member logins, e-commerce or payments, and open-ended design
      sprints—brochure-style sites only; I can point you to partners for the rest.
    </p>
  </div>
</section>
