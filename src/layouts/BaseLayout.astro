---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
const { title = "Perennial Web Studio", bodyClass = "" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Playfair+Display:wght@600;700&display=swap"
  rel="stylesheet"
/>
    <link rel="icon" type="image/png" href="/favicon-leaves-rounded.png?v=7" />
    <link rel="apple-touch-icon" href="/favicon-leaves-rounded.png?v=7" />

    <title>{title}</title>

    {
      import.meta.env.PROD && (
        <>
          {/* Google tag (gtag.js) — prod only */}
          <script
            async
            src="https://www.googletagmanager.com/gtag/js?id=G-MKL50B4T5T"
          />
          <script is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", "G-MKL50B4T5T");
          </script>
        </>
      )
    }
  </head>
  <body class:list={[bodyClass]}>
    <script is:inline>
      (function () {
        try {
          if (!document.body.classList.contains("site-body--home")) return;
          if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
          document.documentElement.classList.add("home-scroll-reveal");
        } catch (_) {
          /* no-op */
        }
      })();
    </script>
    <Header />
    <main class="site-main">
      <slot />
    </main>
    <Footer />

    <script>
      import { initNavCurrent } from "../lib/navCurrent";
      import { initHomeMotion } from "../lib/homeMotion";
      initNavCurrent();
      initHomeMotion();
    </script>
  </body>
</html>
