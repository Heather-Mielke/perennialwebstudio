---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Terms of Service — Perennial Web Studio" bodyClass="site-body--inner">
  <div class="page-inner">
    <header class="page-head page-head--left">
      <p class="section__eyebrow">Legal</p>
      <h1>Terms of Service</h1>
      <p class="page-head__lede">
        These terms apply to your use of this website and describe how Perennial Web Studio offers information and services
        online. Last updated April 1, 2026.
      </p>
    </header>

    <div class="about-split">
      <div class="about-row">
        <h2 class="about-row__title">Agreement</h2>
        <div class="about-row__body">
          <p>
            By accessing <strong>perennialwebstudio.com</strong> (the “Site”), you agree to these Terms of Service. If you do
            not agree, please do not use the Site. We may update these terms from time to time; the “Last updated” date above
