---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Portfolio — Perennial Web Studio" bodyClass="site-body--inner">
  <div class="page-inner">
    <header class="page-head page-head--left">
      <p class="section__eyebrow">Our Work</p>
      <h1>Portfolio</h1>
    </header>
    <p class="portfolio-empty">
      This portfolio features selected website projects completed for client businesses and shared here with permission.
      Each example reflects practical, conversion-focused work tailored to real services, audiences, and day-to-day
      business goals.
    </p>
  </div>
</BaseLayout>
