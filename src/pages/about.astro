---
import BaseLayout from "../layouts/BaseLayout.astro";
import Process from "../components/Process.astro";
---

<BaseLayout title="About — Perennial Web Studio" bodyClass="site-body--inner">
  <div class="page-inner">
    <header class="page-head page-head--left">
      <p class="section__eyebrow">About</p>
      <h1>Small, fast marketing sites for real-world businesses.</h1>
      <p class="page-head__lede">Nothing flashy for the sake of it.</p>
    </header>

    <div class="about-split">
      <div class="about-row">
        <h2 class="about-row__title">What we believe</h2>
        <div class="about-row__body">
          <p>
            Every business deserves a proper place on the web—a page (or a few) where customers and clients can
            <strong>see who you are, what you offer, how to reach you, and where you’re located</strong> without digging
            through social feeds or outdated listings. You should be able to share one link and feel confident it represents
            you well.
          </p>
        </div>
      </div>

      <div class="about-row">
        <h2 class="about-row__title">Who we are</h2>
        <div class="about-row__body">
          <p>
            Perennial Web Studio is run by <strong>Heather Mielke</strong>, a developer based in Minnesota. The studio focuses
            on building clean, practical websites for small businesses that want something reliable, easy to manage, and
            built with intention—not overcomplicated or hard to update.
          </p>
        </div>
      </div>

      <div class="about-row">
        <h2 class="about-row__title">Where we work</h2>
        <div class="about-row__body">
          <p>
            Perennial Web Studio is <strong>based in Minnesota</strong>. Projects are handled remotely by default, and we’re
            happy to take on work from <strong>anywhere in the United States</strong>—same process, clear communication, and
            no mystery timelines.
          </p>
        </div>
      </div>

      <div class="about-row">
        <h2 class="about-row__title">How we work</h2>
        <div class="about-row__body">
          <p>
            The process stays <strong>simple and straightforward</strong>: we agree on what belongs on the site, build from
            shared components you can preview in advance, review together, adjust as needed, and then launch.
            <strong>Transparency</strong> matters—what’s included, what isn’t, and what happens after launch are all clearly
            outlined up front so there are no surprises.
          </p>
        </div>
      </div>
    </div>

    <div class="about-actions">
      <hr class="about-actions__rule" />
      <div class="about-actions__btns">
        <a class="button button--primary" href="/#contact">Start a Project</a>
        <a class="button button--secondary" href="/portfolio">See Our Work</a>
      </div>
    </div>
  </div>

  <Process />
</BaseLayout>
